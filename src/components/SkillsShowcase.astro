---
import type { SkillGroup } from '../data/skills';

interface Props {
  groups: SkillGroup[];
}

const { groups } = Astro.props;
---

<div class="skills-showcase" data-reveal aria-label="Technologies maîtrisées">
  {groups.map((group) => (
    <div class="skills-showcase__block">
      <h3 class="skills-showcase__title">{group.label}</h3>
      <ul class="skills-showcase__list">
        {group.items.map((skill) => (
          <li class="skills-showcase__item">
            <span class="skills-showcase__logo">
              <img src={skill.image} alt={skill.alt} width="40" height="40" loading="lazy" />
            </span>
            <span class="skills-showcase__name">{skill.name}</span>
          </li>
        ))}
      </ul>
    </div>
  ))}
</div>

<style>
  .skills-showcase {
    display: flex;
    flex-direction: column;
    gap: 2.5rem;
    cursor: default;
  }

  .skills-showcase__block {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .skills-showcase__title {
    font-family: var(--font-display);
    font-size: 1.25rem;
    font-weight: 600;
    color: var(--parchment);
    letter-spacing: -0.01em;
    padding-bottom: 0.5rem;
    border-bottom: 2px solid var(--teal-bright);
    width: fit-content;
  }

  .skills-showcase__list {
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    gap: 1.25rem 2.5rem;
  }

  .skills-showcase__item {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    pointer-events: none;
    user-select: none;
  }

  .skills-showcase__logo {
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    width: 48px;
    height: 48px;
    padding: 0.4rem;
    background: #ffffff;
    border-radius: 10px;
    box-shadow: 0 1px 6px rgba(0, 0, 0, 0.15);
  }

  .skills-showcase__logo img {
    width: 100%;
    height: 100%;
    object-fit: contain;
  }

  .skills-showcase__name {
    font-family: var(--font-body);
    font-size: 1.05rem;
    font-weight: 500;
    color: var(--parchment-dark);
  }

  @media (max-width: 640px) {
    .skills-showcase__list {
      flex-direction: column;
      gap: 1rem;
    }
  }
</style>
