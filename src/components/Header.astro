---
import { social } from '../data/social';

const nav = [
  { href: '/#competences', label: 'Compétences' },
  { href: '/#projets', label: 'Projets' },
  { href: '/#a-propos', label: 'À propos' },
  { href: '/#contact', label: 'Contact' },
];
---

<header class="header">
  <div class="header__inner container">
    <a href="/" class="header__logo">
      <span class="header__sigil">◈</span>
      <span>GM</span>
    </a>
    <nav class="header__nav" aria-label="Navigation principale">
      {nav.map((item) => (
        <a href={item.href} class="header__link">{item.label}</a>
      ))}
    </nav>
    <div class="header__social">
      <a href={social.github} target="_blank" rel="noopener noreferrer" aria-label="GitHub" class="header__social-link">
        <img src={social.icons.github} alt="" width="22" height="22" loading="lazy" />
      </a>
      <a href={social.linkedin} target="_blank" rel="noopener noreferrer" aria-label="LinkedIn" class="header__social-link">
        <img src={social.icons.linkedin} alt="" width="22" height="22" loading="lazy" />
      </a>
    </div>
  </div>
</header>

<style>
  .header {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    padding: 1rem 0;
    background: linear-gradient(to bottom, rgba(21, 28, 38, 0.94) 50%, transparent);
  }

  .header__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.5rem;
  }

  .header__logo {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--font-display);
    font-size: 1.25rem;
    font-weight: 700;
    letter-spacing: -0.03em;
    color: var(--gold-bright);
    text-decoration: none;
  }

  .header__sigil {
    color: var(--terracotta);
    animation: pulse 3s ease-in-out infinite;
  }

  @keyframes pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.5; }
  }

  .header__nav {
    display: flex;
    gap: clamp(1rem, 3vw, 2rem);
  }

  .header__link {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--parchment-dark);
    text-decoration: none;
    transition: color 0.25s;
  }

  .header__link:hover {
    color: var(--gold-bright);
  }

  .header__social {
    display: flex;
    gap: 0.75rem;
  }

  .header__social-link {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    padding: 0.4rem;
    background: #ffffff;
    border: 1px solid rgba(45, 212, 191, 0.25);
    border-radius: 8px;
    text-decoration: none;
    transition: transform 0.25s, box-shadow 0.25s, border-color 0.25s;
  }

  .header__social-link img {
    width: 22px;
    height: 22px;
    object-fit: contain;
  }

  .header__social-link:hover {
    transform: translateY(-2px);
    border-color: var(--teal-bright);
    box-shadow: 0 4px 16px rgba(45, 212, 191, 0.2);
  }

  @media (max-width: 640px) {
    .header__nav {
      display: none;
    }
  }
</style>
