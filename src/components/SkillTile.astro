---
import type { Skill } from '../data/skills';

interface Props {
  skill: Skill;
  index: number;
}

const { skill, index } = Astro.props;
---

<article
  class="skill-tile ornate-frame"
  data-reveal
  style={`transition-delay: ${index * 0.06}s`}
>
  <div class="skill-tile__icon">
    <img src={skill.image} alt={skill.alt} width="64" height="64" loading="lazy" />
  </div>
  <p class="skill-tile__name">{skill.name}</p>
</article>

<style>
  .skill-tile {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 1rem;
    padding: 1.75rem 1rem;
    text-align: center;
    transition: transform 0.3s var(--ease-out), box-shadow 0.3s;
  }

  .skill-tile:hover {
    transform: translateY(-4px);
    box-shadow: 0 10px 32px rgba(8, 12, 18, 0.35), 0 0 24px rgba(45, 212, 191, 0.1);
  }

  .skill-tile__icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 72px;
    height: 72px;
    padding: 0.65rem;
    background: #ffffff;
    border: 1px solid rgba(45, 212, 191, 0.2);
    border-radius: 12px;
    box-shadow: 0 2px 12px rgba(0, 0, 0, 0.2);
  }

  .skill-tile__icon img {
    width: 100%;
    height: 100%;
    object-fit: contain;
  }

  .skill-tile__name {
    font-family: var(--font-display);
    font-size: 0.95rem;
    font-weight: 600;
    color: var(--parchment);
    letter-spacing: -0.01em;
  }
</style>
