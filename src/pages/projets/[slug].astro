---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { projects, getProject } from '../../data/projects';
import { highlightKeywords } from '../../utils/highlightKeywords';

export function getStaticPaths() {
  return projects.map((project) => ({
    params: { slug: project.slug },
    props: { project },
  }));
}

const { project } = Astro.props;
const badgeClass = `badge--${project.badge}`;
---

<Layout
  title={project.title}
  description={`${project.subtitle} — ${project.teaser}`}
>
  <Header />

  <main class="project-page">
    <div class="project-page__bg" aria-hidden="true"></div>
    <article class="container project">
      <a href="/#projets" class="project__back btn">← Retour aux projets</a>

      <header class="project__header" data-reveal>
        <div class="project__meta">
          <span class={`badge ${badgeClass}`}>{project.badgeLabel}</span>
        </div>
        <h1 class="project__title">{project.title}</h1>
        <p class="project__subtitle">{project.subtitle}</p>
        <div class="project__stack">
          {project.stack.map((tech) => (
            <span class="stack-tag">{tech}</span>
          ))}
        </div>
      </header>

      {project.statusNote && (
        <p class="project__status" data-reveal>{project.statusNote}</p>
      )}

      <section class="project__section ornate-frame" data-reveal>
        <h2 class="project__section-title">Contexte</h2>
        <p set:html={highlightKeywords(project.challenge)} />
      </section>

      {project.features && (
        <section class="project__section ornate-frame" data-reveal>
          <h2 class="project__section-title">Fonctionnalités</h2>
          <ul class="project__list">
            {project.features.map((item) => (
              <li set:html={highlightKeywords(item)} />
            ))}
          </ul>
        </section>
      )}

      {project.images && (
        <section class="project__gallery" data-reveal>
          <h2 class="project__section-title">Aperçu</h2>
          <div class="project__gallery-grid">
            {project.images.map((image) => (
              <figure class="project__figure ornate-frame">
                <img
                  src={image.src}
                  alt={image.alt}
                  loading="lazy"
                  width="1200"
                  height="675"
                />
                <figcaption>{image.caption}</figcaption>
              </figure>
            ))}
          </div>
        </section>
      )}

      <section class="project__section ornate-frame" data-reveal>
        <h2 class="project__section-title">Back-end</h2>
        <ul class="project__list">
          {project.backend.map((item) => (
            <li set:html={highlightKeywords(item)} />
          ))}
        </ul>
      </section>

      <section class="project__section ornate-frame" data-reveal>
        <h2 class="project__section-title">Ce que j'ai construit</h2>
        <ul class="project__list">
          {project.built.map((item) => (
            <li set:html={highlightKeywords(item)} />
          ))}
        </ul>
      </section>

      <footer class="project__footer" data-reveal>
        <div class="project__links">
          {project.links.map((link) => (
            <a href={link.url} target="_blank" rel="noopener noreferrer" class="btn">
              {link.label} ↗
            </a>
          ))}
        </div>
      </footer>
    </article>
  </main>

  <Footer />
</Layout>

<style>
  .project-page {
    position: relative;
    padding: 7rem 0 4rem;
    min-height: 100vh;
  }

  .project-page__bg {
    position: fixed;
    inset: 0;
    background:
      radial-gradient(ellipse 60% 50% at 80% 10%, rgba(45, 212, 191, 0.16) 0%, transparent 50%),
      radial-gradient(ellipse 40% 30% at 10% 90%, rgba(232, 93, 32, 0.09) 0%, transparent 50%);
    pointer-events: none;
    z-index: 0;
  }

  .project {
    position: relative;
    z-index: 1;
    max-width: 900px;
  }

  .project__status {
    font-family: var(--font-mono);
    font-size: 0.78rem;
    letter-spacing: 0.06em;
    color: var(--orange-bright);
    padding: 0.65rem 1rem;
    margin-bottom: 1.75rem;
    border: 1px solid rgba(232, 93, 32, 0.35);
    background: rgba(232, 93, 32, 0.08);
    border-radius: 2px;
  }

  .project__gallery {
    margin-bottom: 1.75rem;
  }

  .project__gallery-grid {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    margin-top: 1.25rem;
  }

  .project__figure {
    padding: 0;
    overflow: hidden;
  }

  .project__figure img {
    width: 100%;
    height: auto;
    display: block;
    border-bottom: 1px solid rgba(45, 212, 191, 0.15);
  }

  .project__figure figcaption {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    letter-spacing: 0.06em;
    color: var(--parchment-dark);
    padding: 0.85rem 1.15rem;
  }

  .project__back {
    margin-bottom: 2.5rem;
    font-size: 0.72rem;
  }

  .project__header {
    margin-bottom: 2.5rem;
  }

  .project__title {
    font-size: clamp(2.5rem, 7vw, 4rem);
    color: var(--teal-bright);
    margin: 0.75rem 0 0.5rem;
  }

  .project__subtitle {
    font-family: var(--font-mono);
    font-size: 0.9rem;
    color: var(--parchment-dark);
    letter-spacing: 0.06em;
    margin-bottom: 1.25rem;
  }

  .project__stack {
    display: flex;
    flex-wrap: wrap;
    gap: 0.45rem;
  }

  .project__section {
    margin-bottom: 1.75rem;
  }

  .project__section-title {
    font-size: 1.5rem;
    color: var(--gold);
    margin-bottom: 1rem;
  }

  .project__section p {
    color: var(--parchment-dark);
    line-height: 1.75;
  }

  .project__section p :global(.kw),
  .project__list :global(.kw) {
    color: var(--teal-bright);
    font-weight: 600;
  }

  .project__list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .project__list li {
    position: relative;
    padding-left: 1.5rem;
    color: var(--parchment-dark);
  }

  .project__list li::before {
    content: '◆';
    position: absolute;
    left: 0;
    color: var(--gold);
    font-size: 0.55rem;
    top: 0.45rem;
  }

  .project__footer {
    margin-top: 2rem;
    padding-top: 2rem;
    border-top: 1px solid rgba(45, 212, 191, 0.18);
  }

  .project__links {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
  }
</style>
