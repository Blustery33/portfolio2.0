---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { projects, getProject } from '../../data/projects';
import { highlightKeywords } from '../../utils/highlightKeywords';
import ProjectGallery from '../../components/ProjectGallery.astro';

export function getStaticPaths() {
  return projects.map((project) => ({
    params: { slug: project.slug },
    props: { project },
  }));
}

const { project } = Astro.props;
const typeBadge = project.type === 'pro' ? 'Pro' : 'Perso';
const typeClass = `project__header--${project.type}`;
---

<Layout
  title={project.title}
  description={`${project.subtitle} — ${project.teaser}`}
>
  <Header />

  <main class="project-page">
    <div class="project-page__bg" aria-hidden="true"></div>
    <article class="container project">
      <a href="/#projets" class="project__back btn">← Retour aux projets</a>

      <header class={`project__header ${typeClass}`} data-reveal>
        <div class="project__title-row">
          <h1 class="project__title">{project.title}</h1>
          <span class="project__badge">{typeBadge}</span>
        </div>
        {project.meta && <p class="project__meta">{project.meta}</p>}
        <p class="project__subtitle">{project.subtitle}</p>
        <div class="project__stack">
          {project.stack.map((tech) => (
            <span class="stack-tag">{tech}</span>
          ))}
        </div>
      </header>

      {project.statusNote && (
        <p class="project__status" data-reveal>{project.statusNote}</p>
      )}

      <section class="project__section ornate-frame" data-reveal>
        <h2 class="project__section-title">Contexte</h2>
        <p set:html={highlightKeywords(project.challenge)} />
      </section>

      {project.features && (
        <section class="project__section ornate-frame" data-reveal>
          <h2 class="project__section-title">Fonctionnalités</h2>
          <ul class="project__list">
            {project.features.map((item) => (
              <li set:html={highlightKeywords(item)} />
            ))}
          </ul>
        </section>
      )}

      <section class="project__section ornate-frame" data-reveal>
        <h2 class="project__section-title">Back-end</h2>
        <ul class="project__list">
          {project.backend.map((item) => (
            <li set:html={highlightKeywords(item)} />
          ))}
        </ul>
      </section>

      <section class="project__section ornate-frame" data-reveal>
        <h2 class="project__section-title">Ce que j'ai construit</h2>
        <ul class="project__list">
          {project.built.map((item) => (
            <li set:html={highlightKeywords(item)} />
          ))}
        </ul>
      </section>

      {project.images && <ProjectGallery images={project.images} />}

      <footer class="project__footer" data-reveal>
        <div class="project__links">
          {project.links.map((link) => (
            <a href={link.url} target="_blank" rel="noopener noreferrer" class="btn">
              {link.label} ↗
            </a>
          ))}
        </div>
      </footer>
    </article>
  </main>

  <Footer />
</Layout>

<style>
  .project-page {
    position: relative;
    padding: 7rem 0 4rem;
    min-height: 100vh;
  }

  .project-page__bg {
    position: fixed;
    inset: 0;
    background:
      radial-gradient(ellipse 60% 50% at 80% 10%, rgba(45, 212, 191, 0.16) 0%, transparent 50%),
      radial-gradient(ellipse 40% 30% at 10% 90%, rgba(232, 93, 32, 0.09) 0%, transparent 50%);
    pointer-events: none;
    z-index: 0;
  }

  .project {
    position: relative;
    z-index: 1;
    max-width: 900px;
  }

  .project__status {
    font-family: var(--font-mono);
    font-size: 0.78rem;
    letter-spacing: 0.06em;
    color: var(--orange-bright);
    padding: 0.65rem 1rem;
    margin-bottom: 1.75rem;
    border: 1px solid rgba(232, 93, 32, 0.35);
    background: rgba(232, 93, 32, 0.08);
    border-radius: 2px;
  }

  .project__back {
    margin-bottom: 2.5rem;
    font-size: 0.72rem;
  }

  .project__header {
    margin-bottom: 2.5rem;
  }

  .project__title-row {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 1rem;
    margin-bottom: 0.5rem;
  }

  .project__title {
    font-family: var(--font-display);
    font-size: clamp(2rem, 6vw, 2.75rem);
    font-weight: 700;
    letter-spacing: -0.02em;
    line-height: 1.1;
    margin: 0;
    padding-bottom: 0.65rem;
    border-bottom: 2px solid transparent;
  }

  .project__header--pro .project__title {
    color: var(--teal-bright);
    border-image: linear-gradient(90deg, var(--teal-bright), transparent) 1;
  }

  .project__header--perso .project__title {
    background: linear-gradient(110deg, var(--orange-bright) 0%, #f4c97a 45%, var(--teal-bright) 100%);
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
    border-image: linear-gradient(90deg, var(--orange-bright), var(--teal-bright), transparent) 1;
  }

  .project__badge {
    flex-shrink: 0;
    font-family: var(--font-mono);
    font-size: 0.65rem;
    font-weight: 500;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    padding: 0.28rem 0.55rem;
    border-radius: 2px;
    margin-top: 0.35rem;
    opacity: 0.8;
  }

  .project__header--pro .project__badge {
    color: var(--teal-bright);
    background: rgba(45, 212, 191, 0.1);
    border: 1px solid rgba(45, 212, 191, 0.3);
  }

  .project__header--perso .project__badge {
    color: var(--orange-bright);
    background: rgba(232, 93, 32, 0.12);
    border: 1px solid rgba(255, 140, 66, 0.35);
  }

  .project__meta {
    font-family: var(--font-mono);
    font-size: 0.78rem;
    letter-spacing: 0.03em;
    color: var(--parchment-dark);
    line-height: 1.45;
    margin-bottom: 0.35rem;
  }

  .project__subtitle {
    font-family: var(--font-mono);
    font-size: 0.9rem;
    color: var(--parchment-dark);
    letter-spacing: 0.06em;
    margin-bottom: 1.25rem;
  }

  .project__stack {
    display: flex;
    flex-wrap: wrap;
    gap: 0.45rem;
  }

  .project__section {
    margin-bottom: 1.75rem;
  }

  .project__section-title {
    font-size: 1.5rem;
    color: var(--gold);
    margin-bottom: 1rem;
  }

  .project__section p {
    color: var(--parchment-dark);
    line-height: 1.75;
  }

  .project__section p :global(.kw),
  .project__list :global(.kw) {
    color: var(--teal-bright);
    font-weight: 600;
  }

  .project__list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .project__list li {
    position: relative;
    padding-left: 1.5rem;
    color: var(--parchment-dark);
  }

  .project__list li::before {
    content: '◆';
    position: absolute;
    left: 0;
    color: var(--gold);
    font-size: 0.55rem;
    top: 0.45rem;
  }

  .project__footer {
    margin-top: 2rem;
    padding-top: 2rem;
    border-top: 1px solid rgba(45, 212, 191, 0.18);
  }

  .project__links {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
  }
</style>
